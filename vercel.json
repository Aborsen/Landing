{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "redirects": [
    { "source": "/Platform/AI%20Chat", "destination": "/platform/ai-chat", "permanent": true },
    { "source": "/Platform/Semantic%20Layer", "destination": "/platform/semantic-layer", "permanent": true },
    { "source": "/Solutions/Marketing%20Teams", "destination": "/solutions/marketing-teams", "permanent": true },
    { "source": "/Solutions/RevOps%20BizOps", "destination": "/solutions/revenue-teams", "permanent": true },
    { "source": "/Solutions/Founders%20CEOs", "destination": "/solutions/executive-teams", "permanent": true },
    { "source": "/Solutions/Product%20Teams", "destination": "/solutions/product-teams", "permanent": true },
    { "source": "/Solutions/Data%20Analytics%20Teams", "destination": "/solutions/analytics-teams", "permanent": true },
    { "source": "/solutions/revops-bizops", "destination": "/solutions/revenue-teams", "permanent": true },
    { "source": "/solutions/founders-ceos", "destination": "/solutions/executive-teams", "permanent": true },
    { "source": "/solutions/operations-finance", "destination": "/solutions/finance-teams", "permanent": true },
    { "source": "/solutions/data-analytics-teams", "destination": "/solutions/analytics-teams", "permanent": true },
    { "source": "/Solutions/Operations%20Finance", "destination": "/solutions/finance-teams", "permanent": true },
    { "source": "/Resources/Contact%20Support", "destination": "/resources/contact-support", "permanent": true },
    { "source": "/Resources/Prompt%20Library", "destination": "/resources/prompt-library", "permanent": true },
    { "source": "/Company/About%20Insightis", "destination": "/company/about-insightis", "permanent": true },
    { "source": "/Company/Press%20Media", "destination": "/company/press-media", "permanent": true },
    { "source": "/Company/Success%20Stories", "destination": "/company/success-stories", "permanent": true },
    { "source": "/Security/Cookie%20Settings", "destination": "/security/cookie-settings", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": ".*\\.vercel\\.app" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ]
}
